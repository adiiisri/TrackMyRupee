PORT=5000
NODE_ENV=development

# Database
# Instructions: Sign up at https://mongodb.com/cloud/atlas, create a free cluster, and get your connection string.
# Replace <password> with your actual database user password.
# Example: mongodb+srv://myuser:mypassword@cluster0.abcde.mongodb.net/expense_tracker
MONGO_URI=mongodb://localhost:27017/expense_tracker

# Local Auth JWT Secret
JWT_SECRET=super_secret_jwt_key_change_in_production
JWT_EXPIRE=30d

# Google OAuth Setup
# Instructions: Go to https://console.cloud.google.com/
# 1. Create a new project.
# 2. Go to "APIs & Services" > "Credentials".
# 3. Create Credentials > OAuth client ID.
# 4. Set Application type to "Web application".
# 5. Add Authorized redirect URIs: http://localhost:5000/api/auth/google/callback
# 6. Copy the Client ID and Client Secret here.
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL for CORS and Google Redirect
FRONTEND_URL=http://localhost:5173
